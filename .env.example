# Twitch Application Credentials
TWITCH_APP_ID=your_twitch_app_id_here
TWITCH_APP_SECRET=your_twitch_app_secret_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Twitch browser OAuth token for Streamlink
STREAMLINK_OAUTH_TOKEN=your_streamlink_oauth_token_here

# Channels to join, comma-separated (leave empty to join bot's own channel)
TARGET_CHANNELS=Vaarattu,Vaarabot

# Optional stream audio transcription
TRANSCRIPTION_ENABLED=false
TRANSCRIPTION_CHANNEL=
TRANSCRIPTION_MODEL=small
TRANSCRIPTION_DEVICE=cpu
TRANSCRIPTION_COMPUTE_TYPE=int8
TRANSCRIPTION_LANGUAGE=
TRANSCRIPTION_STREAM_QUALITY=480p
TRANSCRIPTION_CHUNK_SECONDS=10.0
TRANSCRIPTION_OVERLAP_SECONDS=1.0
TRANSCRIPTION_RECONNECT_DELAY=15.0
TRANSCRIPTION_VAD_FILTER=true
TRANSCRIPTION_CONTEXT_LIMIT=6
TRANSCRIPTION_AUDIO_QUEUE_MAX_SIZE=30
TRANSCRIPTION_PAUSE_WHILE_LLM_BUSY=true
INPUT_QUEUE_MAX_SIZE=20
INPUT_QUEUE_MIN_RESPONSE_INTERVAL=2.0
INPUT_QUEUE_MAX_AGE_SECONDS=180.0
STREAMER_SPEECH_RESPONSES_ENABLED=true
STREAMER_SPEECH_QUIET_SECONDS=4.0
STREAMER_SPEECH_MAX_UTTERANCE_SECONDS=30.0
STREAMER_SPEECH_MIN_WORDS=5
STREAMER_SPEECH_RESPONSE_COOLDOWN_SECONDS=90.0
STREAMER_SPEECH_MAX_PENDING=1

# Google Custom Search API (for web search functionality)
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
